rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isTeacher() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'photoURL', 'role', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['teacher', 'student'] &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // For listing teachers/students
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                      incoming().displayName is string && incoming().displayName.size() <= 100;
    }

    // Stream Validation
    function isValidStream(data) {
      return data.keys().hasAll(['title', 'description', 'teacherId', 'teacherName', 'status', 'thumbnail', 'viewersCount', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 9 &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['live', 'offline', 'scheduled'] &&
             data.teacherId == request.auth.uid &&
             data.viewersCount is number &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /streams/{streamId} {
      allow read: if isSignedIn();
      allow create: if isTeacher() && isValidStream(incoming());
      allow update: if isSignedIn() && (
        // Teacher owner update
        (isOwner(existing().teacherId) && 
         incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'status', 'thumbnail', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||
        // Viewer count increment (simplified for demo, usually needs a counter doc)
        (incoming().diff(existing()).affectedKeys().hasOnly(['viewersCount']) &&
         incoming().viewersCount is number)
      );
      allow delete: if isTeacher() && isOwner(existing().teacherId);
    }

    // Chat Validation
    function isValidChatMessage(data) {
      return data.keys().hasAll(['text', 'userId', 'userName', 'userPhoto', 'timestamp']) &&
             data.keys().size() == 5 &&
             data.text is string && data.text.size() <= 500 &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time;
    }

    match /streams/{streamId}/chat/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidChatMessage(incoming());
    }
  }
}
