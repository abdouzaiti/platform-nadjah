{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "role"]
    },
    "Stream": {
      "title": "Stream",
      "description": "Live stream metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "status": { "type": "string", "enum": ["live", "offline", "scheduled"] },
        "thumbnail": { "type": "string" },
        "viewersCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "teacherId", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Real-time chat messages for a stream",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "userId", "userName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/streams/{streamId}": {
      "schema": "Stream",
      "description": "Active and past streams"
    },
    "/streams/{streamId}/chat/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages for a specific stream"
    }
  }
}
